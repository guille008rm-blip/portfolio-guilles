    0%, 100% { opacity: 1; }
    50% { opacity: 0.3; }
  }

  .channel-switch__label {
    font-family: 'Syne Variable', sans-serif;
    font-size: var(--step-0);
    font-weight: 700;
    letter-spacing: -0.01em;
  }

  .channel-switch__badge {
    font-size: var(--step--2);
