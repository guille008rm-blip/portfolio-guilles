  /* ── Glitch transition overlay ── */
  .channel-glitch {
    position: fixed;
    inset: 0;
    z-index: 9998;
    pointer-events: none;
    opacity: 0;
    visibility: hidden;
  }

  .channel-glitch.glitch--active {
    opacity: 1;
    visibility: visible;
    animation: glitch-master 0.7s steps(6) forwards;
  }

  /* RGB chromatic split layers */
  .channel-glitch__rgb {
    position: absolute;
    inset: 0;
    mix-blend-mode: screen;
    opacity: 0;
  }

  .glitch--active .channel-glitch__rgb--r {
    background: rgba(255, 0, 0, 0.15);
    animation: glitch-rgb-r 0.7s steps(3) forwards;
  }

  .glitch--active .channel-glitch__rgb--g {
    background: rgba(0, 255, 0, 0.1);
    animation: glitch-rgb-g 0.7s steps(4) forwards;
  }

  .glitch--active .channel-glitch__rgb--b {
    background: rgba(0, 100, 255, 0.15);
    animation: glitch-rgb-b 0.7s steps(3) forwards;
  }

  @keyframes glitch-rgb-r {
    0%   { opacity: 0; transform: translate(0, 0); }
    10%  { opacity: 1; transform: translate(-8px, 2px); }
    25%  { opacity: 0.8; transform: translate(12px, -3px); }
    40%  { opacity: 1; transform: translate(-5px, 1px); }
    60%  { opacity: 0.6; transform: translate(6px, -1px); }
    80%  { opacity: 0.3; transform: translate(-2px, 0); }
    100% { opacity: 0; transform: translate(0, 0); }
  }

  @keyframes glitch-rgb-g {
    0%   { opacity: 0; transform: translate(0, 0); }
    15%  { opacity: 0.8; transform: translate(6px, -4px); }
    30%  { opacity: 1; transform: translate(-10px, 2px); }
    50%  { opacity: 0.7; transform: translate(4px, 3px); }
    70%  { opacity: 0.4; transform: translate(-3px, -1px); }
    100% { opacity: 0; transform: translate(0, 0); }
  }

  @keyframes glitch-rgb-b {
    0%   { opacity: 0; transform: translate(0, 0); }
    12%  { opacity: 1; transform: translate(10px, 3px); }
    28%  { opacity: 0.9; transform: translate(-8px, -2px); }
    45%  { opacity: 1; transform: translate(5px, -4px); }
    65%  { opacity: 0.5; transform: translate(-4px, 2px); }
    85%  { opacity: 0.2; transform: translate(2px, 0); }
    100% { opacity: 0; transform: translate(0, 0); }
  }

  .channel-glitch__static {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent 0px,
        rgba(0, 212, 255, 0.06) 1px,
        transparent 2px
      ),
      repeating-linear-gradient(
        90deg,
        transparent 0px,
        rgba(255, 255, 255, 0.02) 1px,
        transparent 3px
      );
    mix-blend-mode: screen;
  }

  .channel-glitch__static::before {
    content: '';
    position: absolute;
    inset: 0;
    background: url("data:image/svg+xml,%3Csvg viewBox='0 0 256 256' xmlns='http://www.w3.org/2000/svg'%3E%3Cfilter id='noise'%3E%3CfeTurbulence type='fractalNoise' baseFrequency='0.85' numOctaves='5' stitchTiles='stitch'/%3E%3C/filter%3E%3Crect width='100%25' height='100%25' filter='url(%23noise)' opacity='0.6'/%3E%3C/svg%3E");
    background-size: 256px 256px;
    opacity: 0;
  }

  .glitch--active .channel-glitch__static::before {
    animation: glitch-noise 0.7s steps(8) forwards;
  }

  @keyframes glitch-noise {
    0%   { opacity: 0; }
    10%  { opacity: 0.9; }
    20%  { opacity: 0.4; }
    35%  { opacity: 1; }
    50%  { opacity: 0.7; }
    65%  { opacity: 0.5; }
    80%  { opacity: 0.2; }
    100% { opacity: 0; }
  }

  .channel-glitch__bars {
    position: absolute;
    inset: 0;
    background: repeating-linear-gradient(
      0deg,
      transparent 0,
      transparent 2px,
      rgba(0, 0, 0, 0.25) 2px,
      rgba(0, 0, 0, 0.25) 4px
    );
    opacity: 0;
  }

  .glitch--active .channel-glitch__bars {
    animation: glitch-bars 0.7s steps(4) forwards;
  }

  @keyframes glitch-bars {
    0%   { opacity: 0; transform: translateY(0); }
    15%  { opacity: 0.8; transform: translateY(-30%); }
    30%  { opacity: 1; transform: translateY(15%); }
    50%  { opacity: 0.7; transform: translateY(-10%); }
    70%  { opacity: 0.4; transform: translateY(5%); }
