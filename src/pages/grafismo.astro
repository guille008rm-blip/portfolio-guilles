---
import SectionLayout from '../layouts/SectionLayout.astro';
import ProjectCard from '../components/grafismo/ProjectCard.astro';
import { grafismoProjects } from '../data/projects';
---

<SectionLayout
  title="Grafismo en TV — Guillermo López"
  description="Grafismo en directo, motion graphics y gráfica televisiva para las principales cadenas de España."
  theme="grafismo"
>
  <!-- Hero broadcast -->
  <section class="grafismo-hero">
    <div class="grafismo-hero__overlay">
      <div class="scanline"></div>
    </div>

    <div class="grafismo-hero__content container">
      <div class="grafismo-hero__labels">
        <span class="grafismo-label mono">REC ●</span>
        <span class="grafismo-label mono">LIVE</span>
        <span class="grafismo-label mono">16:9 — 1080p</span>
      </div>

      <div class="grafismo-hero__timecode mono" aria-hidden="true">
        <span id="timecode">00:00:00:00</span>
      </div>

      <h1 class="grafismo-hero__title" data-animate="fade-up">
        Grafismo<br />
        <span class="grafismo-hero__accent">en TV</span>
      </h1>

      <p class="grafismo-hero__subtitle" data-animate="fade-up">
        Emisión en directo. Motion graphics. Identidad televisiva.
        Más de 5 años creando la imagen que ves en pantalla.
      </p>

      <div class="grafismo-hero__frame" aria-hidden="true">
        <div class="frame-corner frame-corner--tl"></div>
        <div class="frame-corner frame-corner--tr"></div>
        <div class="frame-corner frame-corner--bl"></div>
        <div class="frame-corner frame-corner--br"></div>
      </div>
    </div>
  </section>

  <!-- Experience bar -->
  <section class="grafismo-exp section">
    <div class="container">
      <div class="grafismo-exp__bar" data-animate="fade-up">
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">Mediaset</span>
          <span class="grafismo-exp__label mono">Actual</span>
        </div>
        <div class="grafismo-exp__divider"></div>
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">RTVE</span>
          <span class="grafismo-exp__label mono">Nacional</span>
        </div>
        <div class="grafismo-exp__divider"></div>
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">Movistar+</span>
          <span class="grafismo-exp__label mono">Plataforma</span>
        </div>
        <div class="grafismo-exp__divider"></div>
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">5+ años</span>
          <span class="grafismo-exp__label mono">Experiencia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Projects -->
  <section class="grafismo-projects section">
    <div class="container">
      <div class="grafismo-projects__header" data-animate="fade-up">
        <span class="mono grafismo-section-label">Proyectos destacados</span>
        <h2 class="grafismo-section-title">Lo que sale en pantalla</h2>
        <p class="grafismo-section-desc">
          Cada proyecto es un equilibrio entre la presión del directo y la exigencia visual.
          Estas son algunas de las piezas que definen mi trabajo en televisión.
        </p>
      </div>

      <div class="grafismo-projects__grid" data-animate="stagger">
        {grafismoProjects.map((project) => (
          <ProjectCard
            title={project.title}
            description={project.description}
            tags={project.tags}
            featured={project.featured}
          />
        ))}
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="grafismo-tools section">
    <div class="container">
      <div class="grafismo-tools__header" data-animate="fade-up">
        <span class="mono grafismo-section-label">Herramientas</span>
        <h2 class="grafismo-section-title">Stack técnico</h2>
      </div>

      <div class="grafismo-tools__grid" data-animate="stagger">
        <div class="tool-card">
          <span class="tool-card__name">After Effects</span>
          <span class="tool-card__role mono">Motion & Compositing</span>
        </div>
        <div class="tool-card">
          <span class="tool-card__name">Photoshop</span>
          <span class="tool-card__role mono">Diseño & Retoque</span>
        </div>
        <div class="tool-card">
          <span class="tool-card__name">Illustrator</span>
          <span class="tool-card__role mono">Vectorial & Gráfica</span>
        </div>
        <div class="tool-card">
          <span class="tool-card__name">Premiere Pro</span>
          <span class="tool-card__role mono">Edición & Montaje</span>
        </div>
      </div>
    </div>
  </section>
</SectionLayout>

<style>
  /* ── Hero Broadcast ── */
  .grafismo-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    background: var(--grafismo-bg);
    overflow: hidden;
  }

  .grafismo-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 212, 255, 0.015) 2px,
        rgba(0, 212, 255, 0.015) 4px
      );
    pointer-events: none;
  }

  .scanline {
    position: absolute;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.15), transparent);
    animation: scanline 4s linear infinite;
    opacity: 0.6;
  }

  .grafismo-hero__content {
    position: relative;
    z-index: 1;
    padding-top: calc(var(--space-3xl) + 100px);
    padding-bottom: var(--space-3xl);
  }

  .grafismo-hero__labels {
    display: flex;
    gap: var(--space-m);
    margin-bottom: var(--space-xl);
  }

  .grafismo-label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--grafismo-primary);
    padding: 0.2em 0.6em;
    border: 1px solid var(--grafismo-border);
    animation: pulse 3s ease-in-out infinite;
  }

  .grafismo-label:first-child {
    color: var(--grafismo-accent);
    border-color: rgba(255, 23, 68, 0.3);
  }

  .grafismo-hero__timecode {
    position: absolute;
    top: calc(var(--space-3xl) + 100px);
    right: 0;
    font-size: var(--step-0);
    color: var(--grafismo-primary);
    opacity: 0.3;
    letter-spacing: 0.1em;
  }

  .grafismo-hero__title {
    font-size: clamp(3rem, 2rem + 7vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--grafismo-text);
    margin-bottom: var(--space-l);
  }

  .grafismo-hero__accent {
    color: var(--grafismo-primary);
    text-shadow: 0 0 40px rgba(0, 212, 255, 0.3);
  }

  .grafismo-hero__subtitle {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--grafismo-text);
    opacity: 0.65;
    max-width: 50ch;
  }

  /* Frame corners */
  .grafismo-hero__frame {
    position: absolute;
    inset: var(--space-l);
    pointer-events: none;
  }

  .frame-corner {
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: var(--grafismo-primary);
    opacity: 0.3;
  }

  .frame-corner--tl {
    top: 0; left: 0;
    border-top: 1px solid;
    border-left: 1px solid;
  }

  .frame-corner--tr {
    top: 0; right: 0;
    border-top: 1px solid;
    border-right: 1px solid;
  }

  .frame-corner--bl {
    bottom: 0; left: 0;
    border-bottom: 1px solid;
    border-left: 1px solid;
  }

  .frame-corner--br {
    bottom: 0; right: 0;
    border-bottom: 1px solid;
    border-right: 1px solid;
  }

  /* ── Experience Bar ── */
  .grafismo-exp__bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-l);
    padding: var(--space-l);
    border: 1px solid var(--grafismo-border);
    border-radius: var(--radius-md);
    background: var(--grafismo-surface);
    flex-wrap: wrap;
  }

  .grafismo-exp__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .grafismo-exp__value {
    font-family: 'Syne Variable', sans-serif;
    font-size: var(--step-1);
    font-weight: 700;
    color: var(--grafismo-text);
  }

  .grafismo-exp__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--grafismo-primary);
  }

  .grafismo-exp__divider {
    width: 1px;
    height: 40px;
    background: var(--grafismo-border);
  }

  /* ── Section headings ── */
  .grafismo-section-label {
    display: block;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--grafismo-primary);
    margin-bottom: var(--space-xs);
  }

  .grafismo-section-title {
    font-size: var(--step-3);
    color: var(--grafismo-text);
    margin-bottom: var(--space-s);
  }

  .grafismo-section-desc {
    color: var(--grafismo-text);
    opacity: 0.6;
    max-width: 55ch;
    line-height: 1.7;
  }

  /* ── Projects Grid ── */
  .grafismo-projects__header {
    margin-bottom: var(--space-xl);
  }

  .grafismo-projects__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(340px, 1fr));
    gap: var(--space-m);
  }

  /* ── Tools Grid ── */
  .grafismo-tools__header {
    margin-bottom: var(--space-xl);
  }

  .grafismo-tools__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(220px, 1fr));
    gap: var(--space-s);
  }

  .tool-card {
    padding: var(--space-m);
    border: 1px solid var(--grafismo-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .tool-card:hover {
    border-color: var(--grafismo-primary);
  }

  .tool-card__name {
    font-family: 'Syne Variable', sans-serif;
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--grafismo-text);
  }

  .tool-card__role {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--grafismo-primary);
  }

  @media (max-width: 640px) {
    .grafismo-hero__labels {
      flex-wrap: wrap;
      gap: var(--space-xs);
    }

    .grafismo-exp__bar {
      gap: var(--space-m);
    }

    .grafismo-exp__divider {
      display: none;
    }

    .grafismo-projects__grid {
      grid-template-columns: 1fr;
    }
  }
</style>

<script>
  function initTimecode() {
    const el = document.getElementById('timecode');
    if (!el) return;

    let frame = 0;
    function update() {
      const totalSeconds = Math.floor(frame / 25);
      const h = String(Math.floor(totalSeconds / 3600)).padStart(2, '0');
      const m = String(Math.floor((totalSeconds % 3600) / 60)).padStart(2, '0');
      const s = String(totalSeconds % 60).padStart(2, '0');
      const f = String(frame % 25).padStart(2, '0');
      el.textContent = `${h}:${m}:${s}:${f}`;
      frame++;
      requestAnimationFrame(update);
    }
    update();
  }
  document.addEventListener('astro:page-load', initTimecode);
</script>
