<script>
  let grafismoAbort: AbortController | null = null;

  function initGrafismo() {
    // Clean previous listeners when navigating with Astro View Transitions.
    if (grafismoAbort) grafismoAbort.abort();
    grafismoAbort = new AbortController();
    const { signal } = grafismoAbort;

    /* ── Timecode ── */
    const tcEl = document.getElementById('timecode');
    if (tcEl) {
      let frame = 0;
      (function updateTC() {
        const t = Math.floor(frame / 25);
        const h = String(Math.floor(t / 3600)).padStart(2, '0');
        const m = String(Math.floor((t % 3600) / 60)).padStart(2, '0');
        const s = String(t % 60).padStart(2, '0');
        const f = String(frame % 25).padStart(2, '0');
        tcEl.textContent = `${h}:${m}:${s}:${f}`;
        frame++;
        requestAnimationFrame(updateTC);
      })();
    }

    /* ── Channel switch ── */
    const btns = document.querySelectorAll<HTMLButtonElement>('.channel-switch__btn');
    const indicator = document.querySelector<HTMLElement>('.channel-switch__indicator');
    const glitch = document.getElementById('channel-glitch');
    const gridSinIa = document.getElementById('grid-sin-ia');
    const gridIa = document.getElementById('grid-ia');
    const gridCabeceras = document.getElementById('grid-cabeceras');
    const gridChristmas = document.getElementById('grid-christmas');
    const allGrids = [gridSinIa, gridIa, gridCabeceras, gridChristmas];
    const channelMap: Record<string, number> = { 'sin-ia': 0, 'ia': 1, 'cabeceras': 2, 'christmas': 3 };

    let currentChannel = 'sin-ia';
    let switching = false;

    function moveIndicator(btn: HTMLElement) {
      if (!indicator) return;
      const track = btn.parentElement!;
      const trackRect = track.getBoundingClientRect();
      const btnRect = btn.getBoundingClientRect();
      indicator.style.left = (btnRect.left - trackRect.left) + 'px';
      indicator.style.width = btnRect.width + 'px';
    }

    // Position indicator on the initial active button
    const initialActive = document.querySelector<HTMLButtonElement>('.channel-switch__btn--active');
    if (initialActive) moveIndicator(initialActive);

    btns.forEach(btn => {
      btn.addEventListener('click', () => {
        const ch = btn.dataset.channel;
        if (!ch || ch === currentChannel || switching) return;
        switching = true;

        // Update active button
        btns.forEach(b => b.classList.remove('channel-switch__btn--active'));
        btn.classList.add('channel-switch__btn--active');

        // Move indicator
        moveIndicator(btn);

        // Pause all playing videos
        document.querySelectorAll('.gvideo-card video').forEach(v => {
          const vid = v as HTMLVideoElement;
          vid.pause();
          vid.currentTime = 0;
          vid.muted = true;
        });

        // Trigger glitch
        if (glitch) {
          glitch.classList.remove('glitch--active');
          void glitch.offsetWidth; // force reflow

          // Update channel text
          const chText = document.getElementById('glitch-channel-text');
          if (chText) chText.textContent = ch === 'ia' ? 'CON IA' : ch === 'cabeceras' ? 'PRODUCCIONES' : ch === 'christmas' ? 'CORPORATIVO' : 'SIN IA';

          glitch.classList.add('glitch--active');
        }

        // Pause cabecera video if leaving CH 03
        const cabVid = document.getElementById('cabecera-video') as HTMLVideoElement;
        if (cabVid) { cabVid.pause(); cabVid.currentTime = 0; }

        // Switch grids during the glitch peak
        setTimeout(() => {
          allGrids.forEach(g => { if (g) g.classList.add('video-showcase--hidden'); });
          const target = ch === 'ia' ? gridIa : ch === 'cabeceras' ? gridCabeceras : ch === 'christmas' ? gridChristmas : gridSinIa;
          if (target) target.classList.remove('video-showcase--hidden');

          currentChannel = ch!;
          switching = false;
        }, 350);
      }, { signal });
    });

    window.addEventListener('resize', () => {
      const active = document.querySelector<HTMLButtonElement>('.channel-switch__btn--active');
      if (active) moveIndicator(active);
    }, { passive: true, signal });

    /* ── Hover autoplay ── */
    document.querySelectorAll('.gvideo-card').forEach(card => {
      const vid = card.querySelector('video');
      if (!vid) return;

      card.addEventListener('mouseenter', () => {
        vid.muted = false;
        vid.play().catch(() => {});
        card.classList.add('is-playing');
      }, { signal });

      card.addEventListener('mouseleave', () => {
        vid.pause();
        vid.load();
        vid.muted = true;
        card.classList.remove('is-playing');
      }, { signal });
    });

    /* ── Cabecera carousel ── */
    const cabVideo = document.getElementById('cabecera-video') as HTMLVideoElement;
    const cabThumbs = document.querySelectorAll<HTMLButtonElement>('.cabecera-thumb');
    const cabPrev = document.getElementById('cabecera-prev');
    const cabNext = document.getElementById('cabecera-next');
    const cabFS = document.getElementById('cabecera-fullscreen');

    const cabeceraList: { src: string; poster: string; youtube?: boolean }[] = [
      { src: '/media/grafismo/cabeceras/cabecera-zapatero.mp4', poster: '/media/grafismo/cabeceras/cabecera-zapatero-poster.jpg' },
      { src: '/media/grafismo/cabeceras/personas-bestias.mp4', poster: '/media/grafismo/cabeceras/personas-bestias-poster.jpg' },
      { src: 'vYUjhbAhpTc', poster: 'https://img.youtube.com/vi/vYUjhbAhpTc/hqdefault.jpg', youtube: true },
    ];
    let cabIndex = 0;
    const cabYoutube = document.getElementById('cabecera-youtube') as HTMLIFrameElement;

    function setCabecera(idx: number) {
      if (idx < 0 || idx >= cabeceraList.length || !cabVideo) return;
      cabIndex = idx;
      const item = cabeceraList[idx];

      if (item.youtube) {
        cabVideo.pause();
        cabVideo.style.display = 'none';
        if (cabYoutube) {
          cabYoutube.src = `https://www.youtube-nocookie.com/embed/${item.src}?rel=0`;
          cabYoutube.classList.remove('cabecera-player__youtube--hidden');
        }
      } else {
        if (cabYoutube) {
          cabYoutube.classList.add('cabecera-player__youtube--hidden');
          cabYoutube.src = 'about:blank';
        }
        cabVideo.style.display = '';
        cabVideo.pause();
        cabVideo.querySelector('source')!.src = item.src;
        cabVideo.poster = item.poster;
        cabVideo.load();
      }

      cabThumbs.forEach((t, i) => t.classList.toggle('cabecera-thumb--active', i === idx));
    }

    cabThumbs.forEach(t => {
      t.addEventListener('click', () => setCabecera(Number(t.dataset.index)), { signal });
    });

    cabPrev?.addEventListener('click', () => setCabecera((cabIndex - 1 + cabeceraList.length) % cabeceraList.length), { signal });
    cabNext?.addEventListener('click', () => setCabecera((cabIndex + 1) % cabeceraList.length), { signal });

    cabFS?.addEventListener('click', () => {
      if (!cabVideo) return;
      if (cabVideo.requestFullscreen) cabVideo.requestFullscreen();
    }, { signal });
  }

  document.addEventListener('astro:page-load', initGrafismo);

  /* ── Particle system ── */
  function initParticles() {
    const canvas = document.getElementById('grafismo-particles') as HTMLCanvasElement;
    if (!canvas) return;
    const ctx = canvas.getContext('2d');
    if (!ctx) return;

    let w = 0, h = 0;
    let particles: { x: number; y: number; vx: number; vy: number; r: number; a: number; pulse: number; speed: number }[] = [];
    let mouse = { x: -9999, y: -9999 };
    let raf = 0;

    function resize() {
      w = canvas.width = window.innerWidth;
      h = canvas.height = window.innerHeight;
    }

    function createParticles() {
      const count = Math.min(Math.floor((w * h) / 12000), 120);
      particles = [];
      for (let i = 0; i < count; i++) {
        particles.push({
          x: Math.random() * w,
          y: Math.random() * h,
          vx: (Math.random() - 0.5) * 0.3,
          vy: (Math.random() - 0.5) * 0.15 - 0.1,
          r: Math.random() * 1.8 + 0.4,
          a: Math.random() * 0.5 + 0.1,
          pulse: Math.random() * Math.PI * 2,
          speed: Math.random() * 0.02 + 0.008,
        });
      }
    }

    function draw() {
      ctx!.clearRect(0, 0, w, h);

      for (const p of particles) {
        // Drift
        p.x += p.vx;
        p.y += p.vy;
        p.pulse += p.speed;

        // Wrap around
        if (p.x < -10) p.x = w + 10;
        if (p.x > w + 10) p.x = -10;
        if (p.y < -10) p.y = h + 10;
        if (p.y > h + 10) p.y = -10;

        // Mouse repulsion
        const dx = p.x - mouse.x;
        const dy = p.y - mouse.y;
        const dist = Math.sqrt(dx * dx + dy * dy);
        if (dist < 120) {
          const force = (120 - dist) / 120 * 0.8;
          p.x += (dx / dist) * force;
          p.y += (dy / dist) * force;
        }

        // Pulsing alpha
        const alpha = p.a * (0.6 + 0.4 * Math.sin(p.pulse));

        // Draw particle
        ctx!.beginPath();
        ctx!.arc(p.x, p.y, p.r, 0, Math.PI * 2);
        ctx!.fillStyle = `rgba(0, 212, 255, ${alpha})`;
        ctx!.fill();

        // Glow for bigger particles
        if (p.r > 1.2) {
          ctx!.beginPath();
          ctx!.arc(p.x, p.y, p.r * 3, 0, Math.PI * 2);
          ctx!.fillStyle = `rgba(0, 212, 255, ${alpha * 0.1})`;
          ctx!.fill();
        }
      }

      // Draw connection lines between nearby particles
      for (let i = 0; i < particles.length; i++) {
        for (let j = i + 1; j < particles.length; j++) {
          const dx = particles[i].x - particles[j].x;
          const dy = particles[i].y - particles[j].y;
          const dist = Math.sqrt(dx * dx + dy * dy);
          if (dist < 100) {
            const lineAlpha = (1 - dist / 100) * 0.08;
            ctx!.beginPath();
            ctx!.moveTo(particles[i].x, particles[i].y);
            ctx!.lineTo(particles[j].x, particles[j].y);
            ctx!.strokeStyle = `rgba(0, 212, 255, ${lineAlpha})`;
            ctx!.lineWidth = 0.5;
            ctx!.stroke();
          }
        }
      }

      raf = requestAnimationFrame(draw);
    }

    resize();
    createParticles();
    draw();

    window.addEventListener('resize', () => {
      resize();
      createParticles();
    });

    document.addEventListener('mousemove', (e) => {
      mouse.x = e.clientX;
      mouse.y = e.clientY;
    });

    document.addEventListener('mouseleave', () => {
      mouse.x = -9999;
      mouse.y = -9999;
    });

    // Cleanup on page transition
    document.addEventListener('astro:before-preparation', () => {
      cancelAnimationFrame(raf);
    }, { once: true });
  }

  document.addEventListener('astro:page-load', initParticles);
</script>
