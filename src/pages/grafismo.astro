---
import SectionLayout from '../layouts/SectionLayout.astro';
---

<SectionLayout
  title="Grafismo en TV — Guillermo López"
  description="Grafismo en directo, motion graphics y gráfica televisiva para las principales cadenas de España."
  theme="grafismo"
>
  <!-- Particle background -->
  <canvas class="grafismo-particles" id="grafismo-particles" aria-hidden="true"></canvas>

  <!-- Hero broadcast -->
  <section class="grafismo-hero">
    <div class="grafismo-hero__overlay">
      <div class="scanline"></div>
    </div>

    <div class="grafismo-hero__content container">
      <div class="grafismo-hero__labels">
        <span class="grafismo-label mono">REC ●</span>
        <span class="grafismo-label mono">LIVE</span>
        <span class="grafismo-label mono">16:9 — 1080p</span>
      </div>

      <h1 class="grafismo-hero__title" data-animate="fade-up">
        Grafismo<br />
        <span class="grafismo-hero__accent">en TV</span>
      </h1>

      <p class="grafismo-hero__subtitle" data-animate="fade-up">
        Emisión en directo. Motion graphics. Identidad televisiva.
        Más de 5 años creando la imagen que ves en pantalla.
      </p>

      <div class="grafismo-hero__timecode mono" aria-hidden="true">
        <span id="timecode">00:00:00:00</span>
      </div>

      <div class="grafismo-hero__frame" aria-hidden="true">
        <div class="frame-corner frame-corner--tl"></div>
        <div class="frame-corner frame-corner--tr"></div>
        <div class="frame-corner frame-corner--bl"></div>
        <div class="frame-corner frame-corner--br"></div>
      </div>
    </div>
  </section>

  <!-- Experience bar -->
  <section class="grafismo-exp section">
    <div class="container">
      <div class="grafismo-exp__bar" data-animate="fade-up">
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">Mediaset</span>
          <span class="grafismo-exp__label mono">Actual</span>
        </div>
        <div class="grafismo-exp__divider"></div>
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">RTVE</span>
          <span class="grafismo-exp__label mono">Nacional</span>
        </div>
        <div class="grafismo-exp__divider"></div>
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">Movistar+</span>
          <span class="grafismo-exp__label mono">Plataforma</span>
        </div>
        <div class="grafismo-exp__divider"></div>
        <div class="grafismo-exp__item">
          <span class="grafismo-exp__value">5+ años</span>
          <span class="grafismo-exp__label mono">Experiencia</span>
        </div>
      </div>
    </div>
  </section>

  <!-- Channel toggle + Video showcase -->
  <section class="grafismo-showcase section">
    <div class="container">
      <div class="grafismo-showcase__header" data-animate="fade-up">
        <span class="mono grafismo-section-label">Trabajos en emisión</span>
        <h2 class="grafismo-section-title">Lo que sale en pantalla</h2>
        <p class="grafismo-section-desc">
          Cada proyecto es un equilibrio entre la presión del directo y la exigencia visual.
          Pasa el ratón sobre cualquier vídeo para reproducirlo.
        </p>
      </div>

      <!-- Channel selector -->
      <div class="channel-switch" data-animate="fade-up">
        <div class="channel-switch__track">
          <button class="channel-switch__btn channel-switch__btn--active" data-channel="sin-ia" type="button">
            <span class="channel-switch__signal"></span>
            <span class="channel-switch__label">Sin IA</span>
          </button>
          <button class="channel-switch__btn" data-channel="ia" type="button">
            <span class="channel-switch__signal"></span>
            <span class="channel-switch__label">Con IA</span>
          </button>
          <button class="channel-switch__btn" data-channel="cabeceras" type="button">
            <span class="channel-switch__signal"></span>
            <span class="channel-switch__label">Producciones</span>
          </button>
          <button class="channel-switch__btn" data-channel="christmas" type="button">
            <span class="channel-switch__signal"></span>
            <span class="channel-switch__label">Corporativo</span>
          </button>
          <div class="channel-switch__indicator"></div>
        </div>
      </div>

      <!-- Glitch overlay for channel transition -->
      <div class="channel-glitch" id="channel-glitch" aria-hidden="true">
        <div class="channel-glitch__rgb channel-glitch__rgb--r"></div>
        <div class="channel-glitch__rgb channel-glitch__rgb--g"></div>
        <div class="channel-glitch__rgb channel-glitch__rgb--b"></div>
        <div class="channel-glitch__static"></div>
        <div class="channel-glitch__bars"></div>
        <div class="channel-glitch__text mono" id="glitch-channel-text">CH 01</div>
      </div>

      <!-- Sin IA grid -->
      <div class="video-showcase" id="grid-sin-ia">
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/cartela-1-poster.jpg">
            <source src="/media/grafismo/sin-ia/cartela-1.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/discotecas-poster.jpg">
            <source src="/media/grafismo/sin-ia/discotecas.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/elecciones-eeuu-poster.jpg">
            <source src="/media/grafismo/sin-ia/elecciones-eeuu.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/eurocopa-poster.jpg">
            <source src="/media/grafismo/sin-ia/eurocopa.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/graf-1-poster.jpg">
            <source src="/media/grafismo/sin-ia/graf-1.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/narcolanchas-poster.jpg">
            <source src="/media/grafismo/sin-ia/narcolanchas.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/aqui-la-tierra-poster.jpg">
            <source src="/media/grafismo/sin-ia/aqui-la-tierra.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/sin-ia/aqui-la-tierra-2-poster.jpg">
            <source src="/media/grafismo/sin-ia/aqui-la-tierra-2.mp4" type="video/mp4" />
          </video>
        </figure>
      </div>

      <!-- IA grid -->
      <div class="video-showcase video-showcase--hidden" id="grid-ia">
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/che-iglesias-poster.jpg">
            <source src="/media/grafismo/ia/che-iglesias.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/abascal-wars-poster.jpg">
            <source src="/media/grafismo/ia/abascal-wars.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/aforama-poster.jpg">
            <source src="/media/grafismo/ia/aforama.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/begona-desafiante-poster.jpg">
            <source src="/media/grafismo/ia/begona-desafiante.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/hulk-sanchez-poster.jpg">
            <source src="/media/grafismo/ia/hulk-sanchez.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/los-panceta-poster.jpg">
            <source src="/media/grafismo/ia/los-panceta.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/paganos-poster.jpg">
            <source src="/media/grafismo/ia/paganos.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/sanchez-barco-poster.jpg">
            <source src="/media/grafismo/ia/sanchez-barco.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/sanchez-esqui-poster.jpg">
            <source src="/media/grafismo/ia/sanchez-esqui.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/sanchez-lightyear-poster.jpg">
            <source src="/media/grafismo/ia/sanchez-lightyear.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/trileros-sanchez-trump-poster.jpg">
            <source src="/media/grafismo/ia/trileros-sanchez-trump.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/vox-is-coming-poster.jpg">
            <source src="/media/grafismo/ia/vox-is-coming.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/yolanda-oscars-poster.jpg">
            <source src="/media/grafismo/ia/yolanda-oscars.mp4" type="video/mp4" />
          </video>
        </figure>
        <figure class="gvideo-card">
          <video preload="metadata" playsinline muted poster="/media/grafismo/ia/ia-3-poster.jpg">
            <source src="/media/grafismo/ia/ia-3.mp4" type="video/mp4" />
          </video>
        </figure>
      </div>

      <!-- Cabeceras grid (CH 03) -->
      <div class="video-showcase video-showcase--hidden" id="grid-cabeceras">
        <div class="cabecera-player">
          <div class="cabecera-player__frame">
            <div class="cabecera-player__corner cabecera-player__corner--tl"></div>
            <div class="cabecera-player__corner cabecera-player__corner--tr"></div>
            <div class="cabecera-player__corner cabecera-player__corner--bl"></div>
            <div class="cabecera-player__corner cabecera-player__corner--br"></div>

            <video
              id="cabecera-video"
              preload="metadata"
              playsinline
              controls
              poster="/media/grafismo/cabeceras/cabecera-zapatero-poster.jpg"
            >
              <source src="/media/grafismo/cabeceras/cabecera-zapatero.mp4" type="video/mp4" />
            </video>

            <iframe
              id="cabecera-youtube"
              class="cabecera-player__youtube cabecera-player__youtube--hidden"
              width="960"
              height="540"
              src="about:blank"
              title="YouTube video player"
              frameborder="0"
              allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture"
              allowfullscreen
            ></iframe>

            <button class="cabecera-player__fullscreen" id="cabecera-fullscreen" type="button" aria-label="Pantalla completa">
              <svg width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                <polyline points="15 3 21 3 21 9"/><polyline points="9 21 3 21 3 15"/>
                <line x1="21" y1="3" x2="14" y2="10"/><line x1="3" y1="21" x2="10" y2="14"/>
              </svg>
            </button>
          </div>

          <div class="cabecera-player__selector">
            <button class="cabecera-player__prev" id="cabecera-prev" type="button" aria-label="Anterior">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="15 18 9 12 15 6"/></svg>
            </button>

            <div class="cabecera-player__thumbs" id="cabecera-thumbs">
              <button class="cabecera-thumb cabecera-thumb--active" data-index="0" type="button">
                <img src="/media/grafismo/cabeceras/cabecera-zapatero-poster.jpg" alt="Cabecera Zapatero" />
                <span class="mono">Cabecera Zapatero</span>
              </button>
              <button class="cabecera-thumb" data-index="1" type="button">
                <img src="/media/grafismo/cabeceras/personas-bestias-poster.jpg" alt="Personas Bestias" />
                <span class="mono">Personas Bestias</span>
              </button>
              <button class="cabecera-thumb" data-index="2" type="button">
                <img src="https://img.youtube.com/vi/vYUjhbAhpTc/hqdefault.jpg" alt="Midas Alonso" />
                <span class="mono">Midas Alonso</span>
              </button>
            </div>

            <button class="cabecera-player__next" id="cabecera-next" type="button" aria-label="Siguiente">
              <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><polyline points="9 18 15 12 9 6"/></svg>
            </button>
          </div>
        </div>
      </div>
      <!-- Christmas grid (CH 04) -->
      <div class="video-showcase video-showcase--hidden" id="grid-christmas">
        <div class="christmas-intro">
          <span class="mono grafismo-section-label">Diseño corporativo</span>
          <h3 class="christmas-intro__title">Christmas — Producciones Mandarina</h3>
          <p class="christmas-intro__desc">Diseño de tarjetas navideñas corporativas: del concepto digital al resultado impreso.</p>
        </div>

        <div class="christmas-pair">
          <figure class="christmas-card">
            <div class="christmas-card__badge mono">Diseño</div>
            <img src="/media/grafismo/christmas/christmas-1.jpeg" alt="Christmas 1 — Diseño" loading="lazy" />
          </figure>
          <figure class="christmas-card christmas-card--photo">
            <div class="christmas-card__badge mono">Impreso</div>
            <img src="/media/grafismo/christmas/foto-christmas-1.jpeg" alt="Christmas 1 — Impreso" loading="lazy" />
          </figure>
        </div>

        <div class="christmas-pair">
          <figure class="christmas-card">
            <div class="christmas-card__badge mono">Diseño</div>
            <img src="/media/grafismo/christmas/christmas-2.jpeg" alt="Christmas 2 — Diseño" loading="lazy" />
          </figure>
          <figure class="christmas-card christmas-card--photo">
            <div class="christmas-card__badge mono">Impreso</div>
            <img src="/media/grafismo/christmas/foto-christmas-2.png" alt="Christmas 2 — Impreso" loading="lazy" />
          </figure>
        </div>
      </div>
    </div>
  </section>

  <!-- Tools -->
  <section class="grafismo-tools section">
    <div class="container">
      <div class="grafismo-tools__header" data-animate="fade-up">
        <span class="mono grafismo-section-label">Herramientas</span>
        <h2 class="grafismo-section-title">Stack técnico</h2>
      </div>

      <div class="grafismo-tools__grid" data-animate="stagger">
        <div class="tool-card">
          <div class="tool-card__icon">
            <img src="/media/logos/Adobe_After_Effects_CC_icon.svg" alt="After Effects" width="48" height="48" />
          </div>
          <span class="tool-card__name">After Effects</span>
          <span class="tool-card__role mono">Motion & Compositing</span>
        </div>
        <div class="tool-card">
          <div class="tool-card__icon">
            <img src="/media/logos/Adobe_Photoshop_CC_icon.svg" alt="Photoshop" width="48" height="48" />
          </div>
          <span class="tool-card__name">Photoshop</span>
          <span class="tool-card__role mono">Diseño & Retoque</span>
        </div>
        <div class="tool-card">
          <div class="tool-card__icon">
            <img src="/media/logos/Adobe_Illustrator_CC_icon.svg" alt="Illustrator" width="48" height="48" />
          </div>
          <span class="tool-card__name">Illustrator</span>
          <span class="tool-card__role mono">Vectorial & Gráfica</span>
        </div>
        <div class="tool-card">
          <div class="tool-card__icon">
            <img src="/media/logos/Adobe_Premiere_Pro_CC_icon.svg" alt="Premiere Pro" width="48" height="48" />
          </div>
          <span class="tool-card__name">Premiere Pro</span>
          <span class="tool-card__role mono">Edición & Montaje</span>
        </div>
        <div class="tool-card">
          <div class="tool-card__icon">
            <img src="/media/logos/ChatGPT_logo.svg" alt="ChatGPT" width="48" height="48" />
          </div>
          <span class="tool-card__name">ChatGPT</span>
          <span class="tool-card__role mono">IA Generativa</span>
        </div>
        <div class="tool-card">
          <div class="tool-card__icon">
            <img src="/media/logos/freepik-logo-png-transparent.png" alt="Freepik" width="48" height="48" />
          </div>
          <span class="tool-card__name">Freepik</span>
          <span class="tool-card__role mono">Recursos & Assets</span>
        </div>
      </div>
    </div>
  </section>
</SectionLayout>

<style>
  /* ── Hero Broadcast ── */
  .grafismo-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    padding-top: 80px;
    background: var(--grafismo-bg);
    overflow: hidden;
  }

  .grafismo-hero__overlay {
    position: absolute;
    inset: 0;
    background:
      repeating-linear-gradient(
        0deg,
        transparent,
        transparent 2px,
        rgba(0, 212, 255, 0.015) 2px,
        rgba(0, 212, 255, 0.015) 4px
      );
    pointer-events: none;
  }

  .scanline {
    position: absolute;
    width: 100%;
    height: 2px;
    background: linear-gradient(90deg, transparent, rgba(0, 212, 255, 0.15), transparent);
    animation: scanline 4s linear infinite;
    opacity: 0.6;
  }

  .grafismo-hero__content {
    position: relative;
    z-index: 1;
    padding-top: var(--space-xl);
    padding-bottom: var(--space-3xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .grafismo-hero__labels {
    display: flex;
    justify-content: center;
    gap: var(--space-m);
    margin-bottom: var(--space-xl);
  }

  .grafismo-label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--grafismo-primary);
    padding: 0.2em 0.6em;
    border: 1px solid var(--grafismo-border);
    animation: pulse 3s ease-in-out infinite;
  }

  .grafismo-label:first-child {
    color: var(--grafismo-accent);
    border-color: rgba(255, 23, 68, 0.3);
  }

  .grafismo-hero__timecode {
    font-size: var(--step-1);
    color: var(--grafismo-primary);
    opacity: 0.4;
    letter-spacing: 0.15em;
    text-align: center;
    margin-top: var(--space-l);
  }

  .grafismo-hero__title {
    font-size: clamp(3rem, 2rem + 7vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--grafismo-text);
    margin-bottom: var(--space-l);
  }

  @media (max-width: 768px) {
    .grafismo-hero__title {
      font-size: clamp(2rem, 1.2rem + 5.5vw, 3.2rem);
    }

    .grafismo-hero__subtitle {
      font-size: var(--step--1);
      max-width: 30ch;
    }
  }

  .grafismo-hero__accent {
    color: var(--grafismo-primary);
    text-shadow: 0 0 40px rgba(0, 212, 255, 0.3);
  }

  .grafismo-hero__subtitle {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--grafismo-text);
    opacity: 0.65;
    max-width: 50ch;
    text-align: center;
  }

  /* Frame corners */
  .grafismo-hero__frame {
    position: absolute;
    inset: var(--space-l);
    pointer-events: none;
  }

  .frame-corner {
    position: absolute;
    width: 24px;
    height: 24px;
    border-color: var(--grafismo-primary);
    opacity: 0.3;
  }

  .frame-corner--tl { top: 0; left: 0; border-top: 1px solid; border-left: 1px solid; }
  .frame-corner--tr { top: 0; right: 0; border-top: 1px solid; border-right: 1px solid; }
  .frame-corner--bl { bottom: 0; left: 0; border-bottom: 1px solid; border-left: 1px solid; }
  .frame-corner--br { bottom: 0; right: 0; border-bottom: 1px solid; border-right: 1px solid; }

  /* ── Experience Bar ── */
  .grafismo-exp__bar {
    display: flex;
    justify-content: center;
    align-items: center;
    gap: var(--space-l);
    padding: var(--space-l);
    border: 1px solid var(--grafismo-border);
    border-radius: var(--radius-md);
    background: var(--grafismo-surface);
    flex-wrap: wrap;
  }

  .grafismo-exp__item {
    text-align: center;
    display: flex;
    flex-direction: column;
    gap: var(--space-3xs);
  }

  .grafismo-exp__value {
    font-family: 'Syne Variable', sans-serif;
    font-size: var(--step-1);
    font-weight: 700;
    color: var(--grafismo-text);
  }

  .grafismo-exp__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--grafismo-primary);
  }

  .grafismo-exp__divider {
    width: 1px;
    height: 40px;
    background: var(--grafismo-border);
  }

  /* ── Section headings ── */
  .grafismo-section-label {
    display: block;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--grafismo-primary);
    margin-bottom: var(--space-xs);
    text-align: center;
  }

  .grafismo-section-title {
    font-size: var(--step-3);
    color: var(--grafismo-text);
    margin-bottom: var(--space-s);
    text-align: center;
  }

  .grafismo-section-desc {
    color: var(--grafismo-text);
    opacity: 0.6;
    max-width: 55ch;
    line-height: 1.7;
    text-align: center;
    margin-inline: auto;
  }

  /* ── Channel Switch (TV toggle) ── */
