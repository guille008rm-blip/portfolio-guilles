---
import SectionLayout from '../layouts/SectionLayout.astro';
import { automatizacionVisualisers } from '../data/projects';
---

<SectionLayout
  title="Automatización — Guillermo López"
  description="Automatizo procesos de producción visual para trabajar más rápido y con más calidad. Plantillas, scripts y flujos que multiplican la eficiencia."
  theme="automatizacion"
>
  <!-- Hero compacto -->
  <section class="auto-hero">
    <div class="auto-hero__content container">
      <h1 class="auto-hero__title" data-animate="fade-up">
        Automatización
      </h1>

      <p class="auto-hero__subtitle" data-animate="fade-up">
        Me encanta automatizar. Cada proceso repetitivo es una oportunidad
        para crear un sistema que trabaje por mí y me deje centrarme en lo creativo.
      </p>
    </div>

    <!-- Grid pattern background -->
    <div class="auto-hero__grid-bg" aria-hidden="true"></div>
  </section>

  <!-- Showcase cinematográfico -->
  <section class="showcase" aria-label="Visualisers">
    <div class="showcase__viewport">
      {automatizacionVisualisers.map((item, index) => (
        <article
          class={`showcase__slide ${index === 0 ? 'is-active' : ''}`}
          data-index={index}
        >
          <video
            class="showcase__video"
            preload="metadata"
            playsinline
            muted
            loop
            poster={item.poster}
          >
            <source src={item.video} type="video/mp4" />
          </video>

          <div class="showcase__overlay">
            <span class="showcase__counter mono">
              {String(index + 1).padStart(2, '0')} / {String(automatizacionVisualisers.length).padStart(2, '0')}
            </span>
            <h3 class="showcase__title">{item.title}</h3>
            <div class="showcase__tags">
              {item.tags.map((tag) => (
                <span class="showcase__tag mono">{tag}</span>
              ))}
            </div>
          </div>
        </article>
      ))}
    </div>

    <!-- Controles -->
    <button class="showcase__nav showcase__nav--prev" aria-label="Anterior" data-dir="-1">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="15 18 9 12 15 6"/></svg>
    </button>
    <button class="showcase__nav showcase__nav--next" aria-label="Siguiente" data-dir="1">
      <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><polyline points="9 18 15 12 9 6"/></svg>
    </button>

    <!-- Dots -->
    <div class="showcase__dots">
      {automatizacionVisualisers.map((_, i) => (
        <button
          class={`showcase__dot ${i === 0 ? 'is-active' : ''}`}
          data-goto={i}
          aria-label={`Ir a visualiser ${i + 1}`}
        >
          <span class="showcase__dot-fill"></span>
        </button>
      ))}
    </div>
  </section>

  <!-- Workflow diagram -->
  <section class="auto-workflow section">
    <div class="container">
      <div class="auto-workflow__header" data-animate="fade-up">
        <span class="auto-section-label mono">Proceso</span>
        <h2 class="auto-section-title">Cómo automatizo</h2>
        <p class="auto-section-desc">
          Identifico tareas repetitivas, diseño el sistema y lo construyo.
          Lo que antes llevaba horas ahora sale en minutos.
        </p>
      </div>

      <div class="workflow" data-animate="stagger">
        <div class="workflow__step">
          <div class="workflow__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <circle cx="12" cy="12" r="10"/><path d="M12 6v6l4 2"/>
            </svg>
          </div>
          <span class="workflow__number mono">01</span>
          <h3 class="workflow__title">Detección</h3>
          <p class="workflow__desc">Identifico qué procesos se repiten y dónde se pierde tiempo en la producción diaria.</p>
        </div>

        <div class="workflow__arrow" aria-hidden="true">→</div>

        <div class="workflow__step">
          <div class="workflow__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <path d="M2 3h6a4 4 0 014 4v14a3 3 0 00-3-3H2z"/><path d="M22 3h-6a4 4 0 00-4 4v14a3 3 0 013-3h7z"/>
            </svg>
          </div>
          <span class="workflow__number mono">02</span>
          <h3 class="workflow__title">Diseño</h3>
          <p class="workflow__desc">Defino la lógica de la plantilla: estructura modular, variables y puntos de personalización.</p>
        </div>

        <div class="workflow__arrow" aria-hidden="true">→</div>

        <div class="workflow__step">
          <div class="workflow__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polyline points="16 18 22 12 16 6"/><polyline points="8 6 2 12 8 18"/>
            </svg>
          </div>
          <span class="workflow__number mono">03</span>
          <h3 class="workflow__title">Construcción</h3>
          <p class="workflow__desc">Creo la plantilla en After Effects con expresiones, scripts y controles automáticos.</p>
        </div>

        <div class="workflow__arrow" aria-hidden="true">→</div>

        <div class="workflow__step">
          <div class="workflow__icon">
            <svg width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
              <polygon points="13 2 3 14 12 14 11 22 21 10 12 10 13 2"/>
            </svg>
          </div>
          <span class="workflow__number mono">04</span>
          <h3 class="workflow__title">Resultado</h3>
          <p class="workflow__desc">Piezas broadcast-ready en minutos. Cambios de contenido al instante sin rehacer nada.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- Tool stack -->
  <section class="auto-stack section">
    <div class="container">
      <div class="auto-stack__header" data-animate="fade-up">
        <span class="auto-section-label mono">Herramientas</span>
        <h2 class="auto-section-title">Stack de automatización</h2>
      </div>

      <div class="auto-stack__grid" data-animate="stagger">
        <div class="stack-card">
          <div class="stack-card__header">
            <span class="stack-card__name">After Effects</span>
            <span class="stack-card__type mono">Motor</span>
          </div>
          <p class="stack-card__desc">Base de todo: expresiones, scripts y plantillas modulares para producción automatizada.</p>
        </div>
        <div class="stack-card">
          <div class="stack-card__header">
            <span class="stack-card__name">Expresiones</span>
            <span class="stack-card__type mono">Lógica</span>
          </div>
          <p class="stack-card__desc">JavaScript nativo en AE para controlar animaciones, colores y timing sin tocar keyframes.</p>
        </div>
        <div class="stack-card">
          <div class="stack-card__header">
            <span class="stack-card__name">ExtendScript</span>
            <span class="stack-card__type mono">Scripts</span>
          </div>
          <p class="stack-card__desc">Automatización de tareas repetitivas: renderizado por lotes, importación masiva y exports.</p>
        </div>
        <div class="stack-card">
          <div class="stack-card__header">
            <span class="stack-card__name">Essential Graphics</span>
            <span class="stack-card__type mono">Panel</span>
          </div>
          <p class="stack-card__desc">Controles visuales para que cualquier editor modifique contenido sin abrir After Effects.</p>
        </div>
      </div>
    </div>
  </section>

</SectionLayout>

<script is:inline>
  // ── Showcase slider ──
  (() => {
    const slides = document.querySelectorAll('.showcase__slide');
    const dots   = document.querySelectorAll('.showcase__dot');
    const navs   = document.querySelectorAll('.showcase__nav');
    let current  = 0;
    let transitioning = false;

    function goTo(index) {
      if (transitioning || index === current) return;
      transitioning = true;

      const prev = slides[current];
      const next = slides[index];

      // Pause previous
      const prevVideo = prev.querySelector('video');
      if (prevVideo) { prevVideo.pause(); prevVideo.currentTime = 0; }

      // Activate next
      next.classList.add('is-entering');
      requestAnimationFrame(() => {
        next.classList.add('is-active');
        next.classList.remove('is-entering');
        prev.classList.remove('is-active');

        // Play next
        const nextVideo = next.querySelector('video');
        if (nextVideo) nextVideo.play().catch(() => {});

        // Dots
        dots[current].classList.remove('is-active');
        dots[index].classList.add('is-active');

        current = index;
        setTimeout(() => { transitioning = false; }, 600);
      });
    }

    // Nav buttons
    navs.forEach(btn => {
      btn.addEventListener('click', () => {
        const dir = parseInt(btn.dataset.dir);
        const next = (current + dir + slides.length) % slides.length;
        goTo(next);
      });
    });

    // Dots
    dots.forEach(dot => {
      dot.addEventListener('click', () => goTo(parseInt(dot.dataset.goto)));
    });

    // Keyboard
    document.addEventListener('keydown', (e) => {
      if (e.key === 'ArrowRight') goTo((current + 1) % slides.length);
      if (e.key === 'ArrowLeft')  goTo((current - 1 + slides.length) % slides.length);
    });

    // Autoplay first video
    const firstVideo = slides[0]?.querySelector('video');
    if (firstVideo) firstVideo.play().catch(() => {});
  })();
</script>

<style>
  /* ── Hero compacto ── */
  .auto-hero {
    position: relative;
    min-height: auto;
    display: flex;
    align-items: center;
    background: var(--auto-bg);
    overflow: hidden;
  }

  .auto-hero__grid-bg {
    position: absolute;
    inset: 0;
    background-image:
      linear-gradient(rgba(0, 0, 0, 0.03) 1px, transparent 1px),
      linear-gradient(90deg, rgba(0, 0, 0, 0.03) 1px, transparent 1px);
    background-size: 40px 40px;
    mask-image: radial-gradient(ellipse 50% 50% at 70% 50%, black, transparent);
    -webkit-mask-image: radial-gradient(ellipse 50% 50% at 70% 50%, black, transparent);
  }

  .auto-hero__content {
    position: relative;
    z-index: 1;
    padding-top: calc(var(--space-2xl) + 100px);
    padding-bottom: var(--space-l);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .auto-label {
    display: inline-block;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--auto-accent);
    margin-bottom: var(--space-l);
  }

  .auto-hero__title {
    font-size: clamp(2.5rem, 1.5rem + 5vw, 6rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--auto-primary);
    margin-bottom: var(--space-l);
    overflow-wrap: break-word;
  }

  .auto-hero__accent {
    color: var(--auto-accent);
  }

  .auto-hero__subtitle {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--auto-text-secondary);
    max-width: 50ch;
  }

  /* ── Section headings ── */
  .auto-section-label {
    display: block;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--auto-accent);
    margin-bottom: var(--space-xs);
    text-align: center;
  }

  .auto-section-title {
    font-size: var(--step-3);
    color: var(--auto-primary);
    margin-bottom: var(--space-s);
    text-align: center;
  }

  .auto-section-desc {
    color: var(--auto-text-secondary);
    max-width: 55ch;
    line-height: 1.7;
    text-align: center;
    margin-inline: auto;
  }

  /* ── Workflow ── */
  .auto-workflow__header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .workflow {
    display: flex;
    align-items: flex-start;
    gap: var(--space-s);
  }

  .workflow__step {
    flex: 1;
    padding: var(--space-l);
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xs);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .workflow__step:hover {
    border-color: var(--auto-accent);
  }

  .workflow__icon {
    color: var(--auto-accent);
    margin-bottom: var(--space-3xs);
  }

  .workflow__number {
    font-size: var(--step--2);
    color: var(--auto-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
  }

  .workflow__title {
    font-size: var(--step-0);
    color: var(--auto-primary);
    font-weight: 700;
  }

  .workflow__desc {
    font-size: var(--step--1);
    color: var(--auto-text-secondary);
    line-height: 1.6;
  }

  .workflow__arrow {
    font-size: var(--step-1);
    color: var(--auto-accent);
    opacity: 0.4;
    padding-top: var(--space-xl);
    flex-shrink: 0;
  }

  /* ── Stack ── */
  .auto-stack__header {
    margin-bottom: var(--space-xl);
    text-align: center;
  }

  .auto-stack__grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
    gap: var(--space-s);
  }

  .stack-card {
    padding: var(--space-m);
    background: var(--auto-surface);
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-md);
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-xs);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .stack-card:hover {
    border-color: var(--auto-accent);
  }

  .stack-card__header {
    display: flex;
    justify-content: center;
    align-items: baseline;
    gap: var(--space-s);
  }

  .stack-card__name {
    font-family: 'Syne Variable', sans-serif;
    font-size: var(--step-0);
    font-weight: 600;
    color: var(--auto-primary);
  }

  .stack-card__type {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--auto-accent);
    padding: 0.15em 0.5em;
    border: 1px solid var(--auto-border);
    border-radius: var(--radius-sm);
  }

  .stack-card__desc {
    font-size: var(--step--1);
    color: var(--auto-text-secondary);
    line-height: 1.6;
  }

  /* ── Showcase cinematográfico ── */
  .showcase {
    position: relative;
    width: 100%;
    height: 80vh;
    height: 80dvh;
    background: #000;
    overflow: hidden;
  }

  .showcase__viewport {
    position: relative;
    width: 100%;
    height: 100%;
  }

  .showcase__slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    visibility: hidden;
    transition: opacity 0.6s ease, visibility 0.6s ease;
    z-index: 0;
  }

  .showcase__slide.is-active {
    opacity: 1;
    visibility: visible;
    z-index: 1;
  }

  .showcase__slide.is-entering {
    visibility: visible;
  }

  .showcase__video {
    width: 100%;
    height: 100%;
    object-fit: contain;
    display: block;
  }

  /* Overlay con gradiente inferior */
  .showcase__overlay {
    position: absolute;
    inset: auto 0 0 0;
    z-index: 2;
    padding: var(--space-2xl) var(--space-xl) var(--space-xl);
    background: linear-gradient(to top, rgba(0, 0, 0, 0.85) 0%, rgba(0, 0, 0, 0.3) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    align-items: flex-start;
    gap: var(--space-xs);
  }

  .showcase__counter {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: rgba(255, 255, 255, 0.5);
  }

  .showcase__title {
    font-size: clamp(1.6rem, 1rem + 2.5vw, 3rem);
    font-weight: 800;
    color: #fff;
    letter-spacing: -0.02em;
    line-height: 1.1;
  }

  .showcase__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-top: var(--space-3xs);
  }

  .showcase__tag {
    font-size: var(--step--2);
    padding: 0.2em 0.6em;
    border: 1px solid rgba(255, 255, 255, 0.25);
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: rgba(255, 255, 255, 0.75);
  }

  /* Navegación flechas */
  .showcase__nav {
    position: absolute;
    top: 50%;
    transform: translateY(-50%);
    z-index: 3;
    width: 52px;
    height: 52px;
    display: grid;
    place-items: center;
    background: rgba(0, 0, 0, 0.35);
    backdrop-filter: blur(8px);
    -webkit-backdrop-filter: blur(8px);
    border: 1px solid rgba(255, 255, 255, 0.12);
    border-radius: 50%;
    color: #fff;
    cursor: pointer;
    transition: background 0.25s ease, transform 0.25s ease;
  }

  .showcase__nav:hover {
    background: rgba(255, 255, 255, 0.15);
    transform: translateY(-50%) scale(1.08);
  }

  .showcase__nav--prev { left: var(--space-m); }
  .showcase__nav--next { right: var(--space-m); }

  /* Dots */
  .showcase__dots {
    position: absolute;
    bottom: var(--space-m);
    left: 50%;
    transform: translateX(-50%);
    z-index: 3;
    display: flex;
    gap: var(--space-xs);
  }

  .showcase__dot {
    width: 36px;
    height: 4px;
    padding: 0;
    border: none;
    background: rgba(255, 255, 255, 0.25);
    border-radius: 2px;
    cursor: pointer;
    overflow: hidden;
    position: relative;
    transition: background 0.3s ease;
  }

  .showcase__dot.is-active {
    background: rgba(255, 255, 255, 0.5);
  }

  .showcase__dot-fill {
    display: block;
    width: 100%;
    height: 100%;
    background: #fff;
    border-radius: 2px;
    transform: scaleX(0);
    transform-origin: left;
    transition: transform 0.3s ease;
  }

  .showcase__dot.is-active .showcase__dot-fill {
    transform: scaleX(1);
  }

  @media (max-width: 768px) {
    .showcase {
      height: 65vh;
      height: 65dvh;
    }

    .showcase__nav {
      width: 40px;
      height: 40px;
    }

    .showcase__nav--prev { left: var(--space-xs); }
    .showcase__nav--next { right: var(--space-xs); }

    .showcase__overlay {
      padding: var(--space-l) var(--space-m) var(--space-l);
    }

    .workflow {
      flex-direction: column;
    }

    .workflow__arrow {
      padding-top: 0;
      text-align: center;
    }
  }
</style>
