---
import SectionLayout from '../layouts/SectionLayout.astro';
---

<SectionLayout
  title="Desarrollo Web — Guillermo López"
  description="Diseño y desarrollo de productos digitales reales, con criterio visual y enfoque de producto."
  theme="desarrollo"
>
  <!-- Hero -->
  <section class="dev-hero">
    <div class="dev-hero__content container">
      <span class="dev-label mono" data-animate="fade-up">Producto digital · Diseño · Código</span>

      <h1 class="dev-hero__title" data-animate="fade-up">
        Construyo<br />
        <span class="dev-hero__accent">productos digitales</span>
      </h1>

      <p class="dev-hero__subtitle" data-animate="fade-up">
        Vengo del diseño visual y pienso como diseñador, pero entrego
        como desarrollador. Webs, plataformas y sistemas que funcionan
        en producción y resuelven problemas reales.
      </p>

      <span class="dev-hero__tech mono" data-animate="fade-up">
        Next.js · React · TypeScript · Astro · Tailwind · Prisma · Node.js
      </span>
    </div>
  </section>

  <!-- Proyecto 01 — Black Gum (banda oscura) -->
  <section class="dev-casestudy">
    <div class="casestudy-bg"></div>
    <div class="casestudy-inner container" data-animate="fade-up">

      <div class="casestudy-content">
        <img src="/media/blackgum/logo-white.png" alt="Black Gum Studio" class="casestudy-logo" />

        <div class="casestudy-status">
          <span class="casestudy-pulse"></span>
          <span class="casestudy-status__text mono">Construyendo ahora</span>
        </div>

        <p class="casestudy-desc">
          Plataforma full-stack para una productora audiovisual en Madrid.
          Web pública, panel de administración y sistema de pagos — todo
          el stack, del diseño al deploy.
        </p>

        <p class="casestudy-insight">
          "Next.js 14 con App Router y Prisma. Panel admin propio — sin
          WordPress, sin Strapi. Control total."
        </p>

        <span class="casestudy-tech mono">
          Next.js 14 · TypeScript · React · Tailwind · Prisma · Stripe · Node.js
        </span>

        <a href="https://blackgumgroup.com/" target="_blank" rel="noopener noreferrer" class="casestudy-cta__link mono">
          Ver blackgumgroup.com →
        </a>
      </div>
    </div>
  </section>

  <!-- Proyecto 02 — Fratelli Pazzi -->
  <section class="dev-project-section section">
    <div class="container">
      <div class="project-block" data-animate="fade-up">
        <div class="project-block__visual">
          <div class="project-browser">
            <div class="project-browser__bar">
              <div class="browser-dots"><span></span><span></span><span></span></div>
              <span class="browser-url mono">fratellipazzi.es</span>
            </div>
            <div class="project-browser__screen">
              <img src="/media/fratelli/signage/final/cartel-entrada-v2.jpeg" alt="Cartel de Fratelli Pazzi en la pizzería" loading="lazy" />
            </div>
          </div>
        </div>
        <div class="project-block__info">
          <span class="project-status project-status--done mono">Proyecto terminado</span>
          <h2 class="project-block__title">Fratelli Pazzi</h2>
          <p class="project-block__desc">
            Web completa para una pizzería napolitana real que cofundé
            en Las Rozas, Madrid. E-commerce con menú interactivo,
            sistema de pedidos y plataforma de fidelización.
          </p>
          <p class="project-block__insight">
            "Diseñé toda la identidad visual antes de escribir una línea
            de código — la web nace del sistema de marca, no al revés."
          </p>
          <div class="project-block__numbers mono">
            <span>4.7★ Google</span>
            <span class="project-separator">·</span>
            <span>300+ clientes</span>
            <span class="project-separator">·</span>
            <span>Negocio real operando</span>
          </div>
          <a href="https://www.fratellipazzi.es" target="_blank" rel="noopener noreferrer" class="project-block__link mono">
            Ver fratellipazzi.es →
          </a>
        </div>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="dev-cta section">
    <div class="container">
      <div class="dev-cta__inner" data-animate="fade-up">
        <h2 class="dev-cta__title">¿Tienes un proyecto en mente?</h2>
        <a href="/#contacto" class="dev-cta__link mono">Hablemos →</a>
      </div>
    </div>
  </section>
</SectionLayout>

<style>
  /* ── Hero ── */
  .dev-hero {
    position: relative;
    min-height: 100vh;
    min-height: 100dvh;
    display: flex;
    align-items: center;
    background: var(--dev-bg);
  }

  .dev-hero__content {
    position: relative;
    z-index: 1;
    padding-top: calc(var(--space-3xl) + 100px);
    padding-bottom: var(--space-3xl);
    text-align: center;
    display: flex;
    flex-direction: column;
    align-items: center;
  }

  .dev-label {
    display: inline-block;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--dev-accent);
    margin-bottom: var(--space-l);
  }

  .dev-hero__title {
    font-size: clamp(3rem, 2rem + 7vw, 8rem);
    font-weight: 800;
    line-height: 0.95;
    letter-spacing: -0.04em;
    color: var(--dev-primary);
    margin-bottom: var(--space-l);
  }

  .dev-hero__accent {
    color: var(--dev-accent);
  }

  .dev-hero__subtitle {
    font-size: var(--step-1);
    line-height: 1.5;
    color: var(--dev-text-secondary);
    max-width: 48ch;
    margin-bottom: var(--space-l);
  }

  .dev-hero__tech {
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    color: var(--dev-text-secondary);
    opacity: 0.5;
  }

  /* ── Project block (Fratelli) ── */
  .project-block {
    display: grid;
    grid-template-columns: 1.1fr 0.9fr;
    gap: var(--space-xl);
    align-items: center;
  }

  .project-browser {
    border: 1px solid var(--dev-border);
    border-radius: var(--radius-md);
    overflow: hidden;
    background: var(--dev-surface);
    transition: transform var(--duration-base) var(--ease-out),
                box-shadow var(--duration-base) var(--ease-out);
  }

  .project-browser:hover {
    transform: scale(1.015);
    box-shadow: 0 20px 60px rgba(0,0,0,0.08);
  }

  .project-browser__bar {
    display: flex;
    align-items: center;
    gap: var(--space-s);
    padding: var(--space-xs) var(--space-s);
    border-bottom: 1px solid var(--dev-border);
    background: var(--dev-bg);
  }

  .browser-dots {
    display: flex;
    gap: 6px;
  }

  .browser-dots span {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: var(--dev-border);
  }

  .browser-url {
    font-size: var(--step--2);
    color: var(--dev-text-secondary);
    opacity: 0.6;
  }

  .project-browser__screen {
    overflow: hidden;
    background: var(--dev-surface);
  }

  .project-browser__screen img {
    width: 100%;
    height: auto;
    display: block;
  }

  .project-block__info {
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project-status {
    display: inline-flex;
    align-items: center;
    gap: 0.5em;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.12em;
    width: fit-content;
    padding: 0.3em 0.9em;
    border-radius: 999px;
  }

  .project-status--done {
    color: var(--dev-accent);
    border: 1px solid var(--dev-accent);
    opacity: 0.8;
  }

  .project-block__title {
    font-size: var(--step-3);
    font-weight: 800;
    color: var(--dev-primary);
    letter-spacing: -0.02em;
  }

  .project-block__desc {
    font-size: var(--step--1);
    color: var(--dev-text-secondary);
    line-height: 1.7;
  }

  .project-block__insight {
    font-size: var(--step--1);
    font-style: italic;
    color: var(--dev-accent);
    line-height: 1.6;
    padding-left: var(--space-s);
    border-left: 2px solid var(--dev-accent);
    opacity: 0.85;
  }

  .project-block__numbers {
    display: flex;
    flex-wrap: wrap;
    align-items: center;
    gap: 0.5em;
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--dev-primary);
    margin-top: var(--space-2xs);
  }

  .project-separator {
    color: var(--dev-text-secondary);
    opacity: 0.4;
  }

  .project-block__link {
    display: inline-block;
    margin-top: var(--space-xs);
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    color: var(--dev-accent);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .project-block__link:hover {
    transform: translateX(4px);
  }

  /* ── Case Study — Black Gum (dark band) ── */
  .dev-casestudy {
    position: relative;
    overflow: hidden;
    padding-block: var(--space-3xl);
    background: #0b0b0b;
    color: #f5f0e8;
    width: 100vw;
    margin-left: calc(-50vw + 50%);
  }

  .casestudy-bg {
    position: absolute;
    inset: 0;
    background-image: url('/media/blackgum/hero-bg.png');
    background-size: cover;
    background-position: center 30%;
    opacity: 0.08;
    filter: saturate(0.35) brightness(0.5);
    pointer-events: none;
  }

  .casestudy-bg::after {
    content: '';
    position: absolute;
    inset: 0;
    background:
      radial-gradient(ellipse 80% 70% at 50% 40%, transparent 30%, rgba(11,11,11,0.88) 100%),
      linear-gradient(to bottom, rgba(11,11,11,0.75) 0%, transparent 25%, transparent 75%, rgba(11,11,11,0.9) 100%);
  }

  .casestudy-logo {
    width: clamp(160px, 18vw, 240px);
    height: auto;
    filter: drop-shadow(0 0 30px rgba(199,66,46,0.2));
  }

  .casestudy-inner {
    position: relative;
    z-index: 1;
  }

  .casestudy-content {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-m);
    max-width: 580px;
    margin-inline: auto;
  }

  .casestudy-status {
    display: inline-flex;
    align-items: center;
    gap: 0.6em;
    padding: 0.35em 1em;
    border: 1px solid rgba(241,169,58,0.4);
    border-radius: 999px;
  }

  .casestudy-pulse {
    width: 8px;
    height: 8px;
    border-radius: 50%;
    background: #f1a93a;
    animation: pulse-dot 2s ease-in-out infinite;
  }

  @keyframes pulse-dot {
    0%, 100% { opacity: 1; transform: scale(1); }
    50% { opacity: 0.4; transform: scale(0.8); }
  }

  .casestudy-status__text {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: #f1a93a;
  }

  .casestudy-desc {
    font-size: var(--step-0);
    line-height: 1.7;
    color: #d7d1c5;
  }

  .casestudy-insight {
    font-size: var(--step--1);
    font-style: italic;
    line-height: 1.6;
    color: #f1a93a;
    padding-left: var(--space-s);
    border-left: 2px solid rgba(241,169,58,0.5);
    text-align: left;
    opacity: 0.85;
    align-self: center;
    max-width: 460px;
  }

  .casestudy-tech {
    font-size: var(--step--2);
    letter-spacing: 0.06em;
    color: #d7d1c5;
    opacity: 0.45;
  }

  .casestudy-cta__link {
    display: inline-block;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: #0b0b0b;
    background: linear-gradient(135deg, #c7422e, #f1a93a);
    padding: 0.75em 2.2em;
    border-radius: var(--radius-sm);
    font-weight: 600;
    transition: all var(--duration-fast) var(--ease-out);
    box-shadow: 0 4px 20px rgba(199,66,46,0.3);
  }

  .casestudy-cta__link:hover {
    transform: translateY(-3px);
    box-shadow: 0 8px 30px rgba(199,66,46,0.45);
  }

  /* ── CTA ── */
  .dev-cta__inner {
    text-align: center;
    padding-block: var(--space-l);
  }

  .dev-cta__title {
    font-size: var(--step-2);
    color: var(--dev-primary);
    margin-bottom: var(--space-s);
    font-weight: 700;
  }

  .dev-cta__link {
    font-size: var(--step-0);
    color: var(--dev-accent);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .dev-cta__link:hover {
    transform: translateX(6px);
  }

  /* ── Responsive ── */
  @media (max-width: 768px) {
    .dev-hero__title {
      font-size: clamp(2.2rem, 1.2rem + 5vw, 4rem);
    }

    .project-block {
      grid-template-columns: 1fr;
    }

    .casestudy-insight {
      align-self: stretch;
      max-width: 100%;
    }
  }
</style>
