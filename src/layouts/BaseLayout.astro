---
import '@fontsource-variable/inter';
import '@fontsource-variable/syne';
import '@fontsource/jetbrains-mono/400.css';
import '@fontsource/jetbrains-mono/500.css';
import '../styles/global.css';
import '../styles/animations.css';
import { site } from '../data/site';
import Header from '../components/global/Header.astro';
import Footer from '../components/global/Footer.astro';
import { ViewTransitions } from 'astro:transitions';
import Analytics from '@vercel/analytics/astro';

interface Props {
  title?: string;
  description?: string;
  ogImage?: string;
}

const {
  title = site.title,
  description = site.description,
  ogImage = site.ogImage,
} = Astro.props;

const canonicalURL = new URL(Astro.url.pathname, site.url);
---

<!doctype html>
<html lang="es">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="generator" content={Astro.generator} />

    <!-- SEO -->
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonicalURL} />

    <!-- Open Graph -->
    <meta property="og:type" content="website" />
    <meta property="og:url" content={canonicalURL} />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:image" content={new URL(ogImage, site.url)} />
    <meta property="og:locale" content={site.locale} />

    <!-- Twitter -->
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={new URL(ogImage, site.url)} />

    <!-- Favicon -->
    <link rel="icon" type="image/svg+xml" href="/favicon.svg" />

    <!-- View Transitions -->
    <ViewTransitions />
    
    <!-- Vercel Web Analytics -->
    <Analytics />
  </head>
  <body>
    <!-- Global Loader -->
    <div class="gl-loader" id="gl-loader" aria-hidden="true">
      <div class="gl-loader__content">
        <div class="gl-loader__logo">
          <span class="gl-loader__initials">GL</span>
          <div class="gl-loader__scanline"></div>
        </div>
        <div class="gl-loader__progress">
          <div class="gl-loader__bar">
            <div class="gl-loader__fill" id="gl-loader-fill"></div>
          </div>
          <span class="gl-loader__pct mono" id="gl-loader-pct">0%</span>
        </div>
      </div>
      <div class="gl-loader__grid"></div>
    </div>

    <div class="gl-page" id="gl-page">
      <Header />
      <main>
        <slot />
      </main>
      <Footer />
    </div>

    <!-- GSAP -->
    <script>
      import { gsap } from 'gsap';
      import { ScrollTrigger } from 'gsap/ScrollTrigger';

      gsap.registerPlugin(ScrollTrigger);

      function initAnimations() {
        // Kill old ScrollTrigger instances to prevent duplicates across View Transitions
        ScrollTrigger.getAll().forEach(st => st.kill());
        ScrollTrigger.refresh();

        // Fade up elements
        gsap.utils.toArray<HTMLElement>('[data-animate="fade-up"]').forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, y: 40 },
            {
              opacity: 1,
              y: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Stagger elements inside containers
        gsap.utils.toArray<HTMLElement>('[data-animate="stagger"]').forEach((container) => {
          const children = container.children;
          gsap.fromTo(
            children,
            { opacity: 0, y: 30 },
            {
              opacity: 1,
              y: 0,
              duration: 0.6,
              stagger: 0.15,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: container,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Scale in
        gsap.utils.toArray<HTMLElement>('[data-animate="scale-in"]').forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, scale: 0.92 },
            {
              opacity: 1,
              scale: 1,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Slide in left
        gsap.utils.toArray<HTMLElement>('[data-animate="slide-left"]').forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: -50 },
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Slide in right
        gsap.utils.toArray<HTMLElement>('[data-animate="slide-right"]').forEach((el) => {
          gsap.fromTo(
            el,
            { opacity: 0, x: 50 },
            {
              opacity: 1,
              x: 0,
              duration: 0.8,
              ease: 'power3.out',
              scrollTrigger: {
                trigger: el,
                start: 'top 85%',
                once: true,
              },
            }
          );
        });

        // Parallax
        gsap.utils.toArray<HTMLElement>('[data-parallax]').forEach((el) => {
          const speed = parseFloat(el.dataset.parallax || '0.2');
          gsap.to(el, {
            yPercent: speed * 100,
            ease: 'none',
            scrollTrigger: {
              trigger: el,
              start: 'top bottom',
              end: 'bottom top',
              scrub: true,
            },
          });
        });
      }

      // Scroll to hash target after View Transitions (fixes /#contacto)
      function handleHashScroll() {
        const hash = window.location.hash;
        if (hash) {
          const target = document.querySelector(hash);
          if (target) {
            // Wait a tick for layout to settle after View Transition
            requestAnimationFrame(() => {
              requestAnimationFrame(() => {
                target.scrollIntoView({ behavior: 'smooth' });
              });
            });
          }
        }
      }

      // Init on page load and after view transitions
      document.addEventListener('astro:page-load', () => {
        initAnimations();
        handleHashScroll();
      });
    </script>

    <!-- Global Loader Script -->
    <script>
      function initGlobalLoader() {
        const loader = document.getElementById('gl-loader');
        const page = document.getElementById('gl-page');
        const fill = document.getElementById('gl-loader-fill');
        const pctEl = document.getElementById('gl-loader-pct');
        if (!loader || !page) return;

        // If already revealed (back navigation), skip
        if (page.classList.contains('gl-page--visible')) {
          loader.style.display = 'none';
          return;
        }

        const imgs = Array.from(page.querySelectorAll('img:not([loading="lazy"])'));
        const vids = Array.from(page.querySelectorAll('video'));
        const total = imgs.length + vids.length;
        let loaded = 0;
        let revealed = false;

        function tick() {
          loaded++;
          const pct = total > 0 ? Math.round((loaded / total) * 100) : 100;
          if (fill) fill.style.width = pct + '%';
          if (pctEl) pctEl.textContent = pct + '%';
          if (loaded >= total && !revealed) reveal();
        }

        function reveal() {
          if (revealed) return;
          revealed = true;
          // Ensure bar is full
          if (fill) fill.style.width = '100%';
          if (pctEl) pctEl.textContent = '100%';

          // Small delay for polish
          setTimeout(() => {
            loader.classList.add('gl-loader--done');
            page.classList.add('gl-page--visible');
            loader.addEventListener('transitionend', () => {
              loader.style.display = 'none';
            }, { once: true });
          }, 300);
        }

        imgs.forEach(img => {
          if ((img as HTMLImageElement).complete) { tick(); return; }
          img.addEventListener('load', tick, { once: true });
          img.addEventListener('error', tick, { once: true });
        });

        vids.forEach(vid => {
          if ((vid as HTMLVideoElement).readyState >= 2) { tick(); return; }
          vid.addEventListener('loadeddata', tick, { once: true });
          vid.addEventListener('error', tick, { once: true });
        });

        // Fallback: reveal after 6s
        setTimeout(() => { if (!revealed) reveal(); }, 6000);

        // If no assets, reveal immediately
        if (total === 0) reveal();
      }

      document.addEventListener('astro:page-load', initGlobalLoader);
    </script>

    <style is:global>
      /* ── Global Loader ── */
      .gl-loader {
        position: fixed;
        inset: 0;
        z-index: 99999;
        display: flex;
        align-items: center;
        justify-content: center;
        background: #0A0A0F;
        transition: opacity 0.6s cubic-bezier(0.16, 1, 0.3, 1),
                    visibility 0.6s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .gl-loader--done {
        opacity: 0;
        visibility: hidden;
        pointer-events: none;
      }

      .gl-loader__grid {
        position: absolute;
        inset: 0;
        background-image:
          linear-gradient(rgba(255,255,255,0.02) 1px, transparent 1px),
          linear-gradient(90deg, rgba(255,255,255,0.02) 1px, transparent 1px);
        background-size: 60px 60px;
        pointer-events: none;
      }

      .gl-loader__content {
        position: relative;
        z-index: 1;
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 2.5rem;
      }

      /* Logo / Initials */
      .gl-loader__logo {
        position: relative;
        width: 100px;
        height: 100px;
        display: flex;
        align-items: center;
        justify-content: center;
        border: 1px solid rgba(255,255,255,0.08);
        border-radius: 16px;
        overflow: hidden;
      }

      .gl-loader__initials {
        font-family: 'Syne Variable', 'Syne', sans-serif;
        font-size: 2.2rem;
        font-weight: 800;
        letter-spacing: -0.03em;
        color: #FAFAFA;
        animation: gl-pulse 2s ease-in-out infinite;
      }

      .gl-loader__scanline {
        position: absolute;
        inset: 0;
        background: linear-gradient(
          180deg,
          transparent 0%,
          rgba(59, 130, 246, 0.08) 50%,
          transparent 100%
        );
        background-size: 100% 8px;
        animation: gl-scan 1.5s linear infinite;
        pointer-events: none;
      }

      /* Progress */
      .gl-loader__progress {
        display: flex;
        flex-direction: column;
        align-items: center;
        gap: 0.75rem;
        width: clamp(140px, 30vw, 240px);
      }

      .gl-loader__bar {
        width: 100%;
        height: 2px;
        background: rgba(255,255,255,0.06);
        border-radius: 2px;
        overflow: hidden;
      }

      .gl-loader__fill {
        height: 100%;
        width: 0%;
        background: linear-gradient(90deg, #3B82F6, #60A5FA);
        border-radius: 2px;
        transition: width 0.25s ease;
      }

      .gl-loader__pct {
        font-size: 0.7rem;
        letter-spacing: 0.2em;
        text-transform: uppercase;
        color: rgba(255,255,255,0.35);
      }

      /* Page wrapper */
      .gl-page {
        opacity: 0;
        transition: opacity 0.5s cubic-bezier(0.16, 1, 0.3, 1);
      }

      .gl-page--visible {
        opacity: 1;
      }

      @keyframes gl-pulse {
        0%, 100% { opacity: 1; }
        50% { opacity: 0.5; }
      }

      @keyframes gl-scan {
        0% { transform: translateY(-100%); }
        100% { transform: translateY(100%); }
      }
    </style>
  </body>
</html>
