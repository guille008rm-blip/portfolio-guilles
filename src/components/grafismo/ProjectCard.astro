---
interface Props {
  title: string;
  description: string;
  tags: string[];
  featured?: boolean;
}

const { title, description, tags, featured = false } = Astro.props;
---

<article class:list={['project-card', { 'project-card--featured': featured }]}>
  <div class="project-card__visual">
    <div class="project-card__placeholder">
      <svg width="32" height="32" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round">
        <rect x="2" y="3" width="20" height="14" rx="2" ry="2"/><line x1="8" y1="21" x2="16" y2="21"/><line x1="12" y1="17" x2="12" y2="21"/>
      </svg>
    </div>
  </div>
  <div class="project-card__info">
    <h3 class="project-card__title">{title}</h3>
    <p class="project-card__desc">{description}</p>
    <div class="project-card__tags">
      {tags.map((tag) => (
        <span class="project-card__tag mono">{tag}</span>
      ))}
    </div>
  </div>
</article>

<style>
  .project-card {
    display: grid;
    grid-template-rows: auto 1fr;
    border: 1px solid var(--grafismo-border, var(--color-border));
    border-radius: var(--radius-md);
    overflow: hidden;
    transition: transform var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .project-card:hover {
    transform: translateY(-2px);
    border-color: var(--grafismo-primary, var(--color-accent));
  }

  .project-card__visual {
    position: relative;
    aspect-ratio: 16/9;
    overflow: hidden;
  }

  .project-card__placeholder {
    width: 100%;
    height: 100%;
    background: var(--grafismo-surface, var(--color-surface));
    display: flex;
    align-items: center;
    justify-content: center;
    color: var(--grafismo-primary, var(--color-accent));
    opacity: 0.4;
  }

  .project-card--featured .project-card__placeholder {
    background: linear-gradient(135deg, var(--grafismo-bg, #050510), var(--grafismo-muted, #1A1A3A));
  }

  .project-card__info {
    padding: var(--space-m);
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .project-card__title {
    font-size: var(--step-1);
    color: var(--section-text, var(--color-primary));
    font-weight: 700;
  }

  .project-card__desc {
    font-size: var(--step--1);
    line-height: 1.65;
    color: var(--section-text, var(--color-text-secondary));
    opacity: 0.7;
  }

  .project-card__tags {
    display: flex;
    flex-wrap: wrap;
    gap: var(--space-3xs);
    margin-top: var(--space-2xs);
  }

  .project-card__tag {
    font-size: var(--step--2);
    padding: 0.2em 0.6em;
    border: 1px solid var(--grafismo-border, var(--color-border));
    border-radius: var(--radius-sm);
    text-transform: uppercase;
    letter-spacing: 0.05em;
    color: var(--section-text, var(--color-text-secondary));
    opacity: 0.6;
  }
</style>
