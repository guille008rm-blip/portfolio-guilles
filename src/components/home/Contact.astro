---
import Button from '../global/Button.astro';
import { social } from '../../data/site';
---

<section class="contact section" id="contacto">
  <div class="container">
    <div class="contact__inner" data-animate="fade-up">
      <span class="contact__label mono">Contacto</span>

      <h2 class="contact__title">
        ¿Hablamos?
      </h2>

      <p class="contact__text">
        Si te ha gustado lo que has visto, o simplemente te pica la curiosidad,
        escríbeme. Sin compromiso, sin formalidades.
      </p>

      <div class="contact__actions">
        <Button href={`mailto:${social.email}`} variant="primary" size="lg">
          Escribir email
        </Button>
        <Button href={social.linkedin} variant="secondary" size="lg" external>
          LinkedIn
        </Button>
        <Button href="/cv/guillermo-lopez-cv.pdf" variant="ghost" size="md" download>
          Descargar CV ↓
        </Button>
      </div>

      <div class="contact__email mono">
        {social.email}
      </div>
    </div>
  </div>
</section>

<style>
  .contact {
    border-top: 1px solid var(--color-border);
    position: relative;
    overflow: hidden;
  }

  .contact::before {
    content: '';
    position: absolute;
    bottom: -40%;
    left: 50%;
    transform: translateX(-50%);
    width: 80%;
    height: 80%;
    background: radial-gradient(ellipse at center, rgba(59, 130, 246, 0.10) 0%, transparent 70%);
    pointer-events: none;
  }

  .contact__inner {
    text-align: center;
    max-width: 640px;
    margin-inline: auto;
  }

  .contact__label {
    display: inline-block;
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-m);
  }

  .contact__title {
    font-size: var(--step-4);
    color: var(--color-primary);
    margin-bottom: var(--space-m);
  }

  .contact__text {
    font-size: var(--step-0);
    line-height: 1.7;
    color: var(--color-text-secondary);
    margin-bottom: var(--space-xl);
    margin-inline: auto;
  }

  .contact__actions {
    display: flex;
    align-items: center;
    justify-content: center;
    gap: var(--space-s);
    flex-wrap: wrap;
    margin-bottom: var(--space-l);
  }

  .contact__email {
    font-size: var(--step--1);
    color: var(--color-text-secondary);
    letter-spacing: 0.02em;
  }

  @media (max-width: 640px) {
    .contact__actions {
      flex-direction: column;
    }
  }
</style>
