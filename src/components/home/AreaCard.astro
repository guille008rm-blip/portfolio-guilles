---
interface Props {
  title: string;
  description: string;
  href: string;
  theme: 'grafismo' | 'automatizacion' | 'desarrollo' | 'fratelli';
  label: string;
}

const { title, description, href, theme, label } = Astro.props;

const themeColors: Record<string, { gradient: string; accent: string; glow: string }> = {
  grafismo: {
    gradient: 'linear-gradient(135deg, #050510 0%, #0A1628 100%)',
    accent: '#00D4FF',
    glow: 'rgba(0, 212, 255, 0.15)',
  },
  automatizacion: {
    gradient: 'linear-gradient(135deg, #F5F7FA 0%, #E8F5F0 100%)',
    accent: '#00BFA5',
    glow: 'rgba(0, 191, 165, 0.1)',
  },
  desarrollo: {
    gradient: 'linear-gradient(135deg, #F0EDE8 0%, #E8E4DF 100%)',
    accent: '#5B7B9A',
    glow: 'rgba(91, 123, 154, 0.1)',
  },
  fratelli: {
    gradient: 'linear-gradient(135deg, #1E1F1F 0%, #2A2B2B 100%)',
    accent: '#D37968',
    glow: 'rgba(211, 121, 104, 0.15)',
  },
};

const colors = themeColors[theme];
const isLight = theme === 'automatizacion' || theme === 'desarrollo';
---

<a
  href={href}
  class:list={['area-card', `area-card--${theme}`, { 'area-card--light': isLight }]}
  style={`
    --card-gradient: ${colors.gradient};
    --card-accent: ${colors.accent};
    --card-glow: ${colors.glow};
  `}
>
  <div class="area-card__content">
    <span class="area-card__label mono">{label}</span>
    <h3 class="area-card__title">{title}</h3>
    <p class="area-card__desc">{description}</p>
    <span class="area-card__cta mono">
      Explorar →
    </span>
  </div>
  <div class="area-card__glow"></div>
</a>

<style>
  .area-card {
    position: relative;
    display: flex;
    flex-direction: column;
    justify-content: flex-end;
    min-height: 340px;
    padding: var(--space-l);
    background: var(--card-gradient);
    border: 1px solid rgba(255, 255, 255, 0.06);
    border-radius: var(--radius-lg);
    overflow: hidden;
    text-decoration: none;
    transition: transform var(--duration-base) var(--ease-out),
                border-color var(--duration-base) var(--ease-out);
  }

  .area-card--light {
    border-color: rgba(0, 0, 0, 0.06);
  }

  .area-card:hover {
    transform: translateY(-4px);
    border-color: var(--card-accent);
  }

  .area-card__content {
    position: relative;
    z-index: 1;
    display: flex;
    flex-direction: column;
    gap: var(--space-xs);
  }

  .area-card__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--card-accent);
  }

  .area-card__title {
    font-size: var(--step-2);
    font-weight: 700;
    color: #FAFAFA;
    line-height: 1.15;
  }

  .area-card--light .area-card__title {
    color: #1A1A2E;
  }

  .area-card__desc {
    font-size: var(--step--1);
    line-height: 1.6;
    color: rgba(255, 255, 255, 0.6);
    max-width: 38ch;
  }

  .area-card--light .area-card__desc {
    color: rgba(0, 0, 0, 0.55);
  }

  .area-card__cta {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--card-accent);
    margin-top: var(--space-xs);
    transition: transform var(--duration-fast) var(--ease-out);
  }

  .area-card:hover .area-card__cta {
    transform: translateX(4px);
  }

  /* Glow effect on hover */
  .area-card__glow {
    position: absolute;
    top: -50%;
    right: -20%;
    width: 60%;
    height: 100%;
    background: var(--card-glow);
    border-radius: 50%;
    filter: blur(60px);
    opacity: 0;
    transition: opacity var(--duration-slow) var(--ease-out);
    pointer-events: none;
  }

  .area-card:hover .area-card__glow {
    opacity: 1;
  }
</style>
