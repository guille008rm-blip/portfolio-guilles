---
import { experience, skills } from '../../data/experience';
---

<section class="about section" id="sobre-mi">
  <div class="container">
    <div class="about__grid">
      <!-- Left: Photo + Identity -->
      <div class="about__identity" id="about-identity" data-animate="slide-left">
        <div class="about__photo">
          <img
            class="about__photo-img"
            src="/media/guillermo-lopez.jpeg"
            alt="Guillermo López"
            width="300"
            height="400"
            loading="lazy"
          />
        </div>
        <div class="about__quick">
          <h3 class="about__name">Guillermo López</h3>
          <p class="about__role mono">del Castillo-Olivares</p>
          <p class="about__location">Madrid, España</p>
        </div>
      </div>

      <!-- Right: Bio + Experience + Skills -->
      <div class="about__content" data-animate="slide-right">
        <div class="about__bio">
          <p>
            Llevo más de 5 años haciendo grafismo en directo para televisiones nacionales.
            Mediaset, RTVE, Movistar+... ese tipo de presión donde no existe el "lo arreglo luego".
          </p>
          <p>
            En algún momento del camino me di cuenta de que mucho de lo que hacía era repetitivo.
            Así que aprendí a automatizarlo. Después aprendí a hacer webs. Y después monté una pizzería.
            Puede sonar raro, pero todo tiene que ver con lo mismo: resolver problemas y construir cosas que funcionen.
          </p>
        </div>

        <!-- Experience timeline -->
        <div class="about__experience">
          <h4 class="about__subtitle mono">Trayectoria</h4>
          <div class="about__timeline">
            {experience.map((exp) => (
              <div class="timeline__item">
                <div class="timeline__header">
                  <div class="timeline__company-group">
                    {exp.logo && (
                      <img class="timeline__logo" src={exp.logo} alt={exp.company} width="44" height="44" loading="lazy" data-company={exp.company.toLowerCase().replace(/\s+/g, '-')} />
                    )}
                    <span class="timeline__company">{exp.company}</span>
                  </div>
                  <span class="timeline__period mono">{exp.period}</span>
                </div>
                <span class="timeline__role">{exp.role}</span>
              </div>
            ))}
          </div>
        </div>

        <!-- Skills -->
        <div class="about__skills">
          <h4 class="about__subtitle mono">Competencias</h4>
          <div class="about__skill-groups">
            {Object.entries(skills).map(([category, items]) => (
              <div class="skill-group">
                <span class="skill-group__label mono">{category}</span>
                <div class="skill-group__tags">
                  {items.map((skill) => (
                    <span class="skill-tag">{skill}</span>
                  ))}
                </div>
              </div>
            ))}
          </div>
        </div>
      </div>
    </div>
  </div>
</section>

<style>
  .about__grid {
    display: grid;
    grid-template-columns: 300px 1fr;
    gap: var(--space-2xl);
    align-items: start;
  }

  /* Identity column */
  .about__identity {
    position: relative;
    top: auto;
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .about__photo-img {
    width: 100%;
    aspect-ratio: 3/4;
    object-fit: cover;
    border: 1px solid var(--color-border);
    border-radius: var(--radius-md);
  }

  .about__name {
    font-size: var(--step-1);
    color: var(--color-primary);
    font-weight: 700;
  }

  .about__role {
    font-size: var(--step--1);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.05em;
  }

  .about__location {
    font-size: var(--step--1);
    color: var(--color-text-secondary);
    margin-top: var(--space-3xs);
  }

  /* Content column */
  .about__content {
    display: flex;
    flex-direction: column;
    gap: var(--space-l);
  }

  .about__bio {
    display: flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    gap: var(--space-s);
    color: var(--color-text-secondary);
    line-height: 1.75;
  }

  .about__bio p {
    max-width: 60ch;
  }

  .about__subtitle {
    font-size: var(--step--1);
    text-transform: uppercase;
    letter-spacing: 0.15em;
    color: var(--color-accent);
    margin-bottom: var(--space-m);
  }

  /* Timeline */
  .about__timeline {
    display: flex;
    flex-direction: column;
    gap: var(--space-s);
  }

  .timeline__item {
    padding: var(--space-s) var(--space-m);
    border-left: 2px solid var(--color-border);
    transition: border-color var(--duration-fast) var(--ease-out);
  }

  .timeline__item:hover {
    border-left-color: var(--color-accent);
  }

  .timeline__header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    gap: var(--space-s);
    margin-bottom: var(--space-3xs);
  }

  .timeline__company-group {
    display: flex;
    align-items: center;
    gap: var(--space-xs);
    min-width: 0;
  }

  .timeline__logo {
    width: 44px;
    height: 44px;
    object-fit: contain;
    border-radius: 6px;
    flex-shrink: 0;
    opacity: 0.85;
    transition: opacity var(--duration-fast) var(--ease-out);
  }

  .timeline__item:hover .timeline__logo {
    opacity: 1;
  }

  .timeline__company {
    font-weight: 600;
    color: var(--color-primary);
  }

  .timeline__period {
    font-size: var(--step--2);
    color: var(--color-text-secondary);
    text-transform: uppercase;
    letter-spacing: 0.08em;
    white-space: nowrap;
  }

  .timeline__role {
    font-size: var(--step--1);
    color: var(--color-text-secondary);
  }

  /* Skills */
  .about__skill-groups {
    display: flex;
    flex-direction: column;
    gap: var(--space-m);
  }

  .skill-group {
    display: flex;
    flex-direction: column;
    align-items: center;
    gap: var(--space-xs);
  }

  .skill-group__label {
    font-size: var(--step--2);
    text-transform: uppercase;
    letter-spacing: 0.1em;
    color: var(--color-text-secondary);
  }

  .skill-group__tags {
    display: flex;
    flex-wrap: wrap;
    justify-content: center;
    gap: var(--space-3xs);
  }

  .skill-tag {
    display: inline-block;
    padding: 0.25em 0.75em;
    font-size: var(--step--2);
    font-family: 'JetBrains Mono', monospace;
    color: var(--color-text-secondary);
    border: 1px solid var(--color-border);
    border-radius: var(--radius-sm);
    transition: all var(--duration-fast) var(--ease-out);
  }

  .skill-tag:hover {
    border-color: var(--color-accent);
    color: var(--color-accent);
  }

  @media (max-width: 768px) {
    .about__grid {
      grid-template-columns: 1fr;
      gap: var(--space-xl);
    }

    .about__identity {
      position: static;
      flex-direction: row;
      align-items: center;
    }

    .timeline__header {
      flex-direction: row;
      align-items: center;
    }
  }
</style>
